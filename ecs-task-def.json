{
    "family": "unshelvd",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "1024",
    "memory": "2048",
    "executionRoleArn": "arn:aws:iam::261142221895:role/unshelvd-ecs-execution",
    "taskRoleArn": "arn:aws:iam::261142221895:role/unshelvd-ecs-task",
    "containerDefinitions": [
        {
            "name": "unshelvd",
            "image": "261142221895.dkr.ecr.us-east-1.amazonaws.com/unshelvd:latest",
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 8080,
                    "protocol": "tcp"
                }
            ],
            "environment": [
                {
                    "name": "NODE_ENV",
                    "value": "production"
                },
                {
                    "name": "NODE_TLS_REJECT_UNAUTHORIZED",
                    "value": "0"
                },
                {
                    "name": "PORT",
                    "value": "8080"
                },
                {
                    "name": "APP_URL",
                    "value": "https://unshelvd.koshkikode.com"
                },
                {
                    "name": "PUBLIC_APP_URL",
                    "value": "https://unshelvd.koshkikode.com"
                },
                {
                    "name": "WEB_BASE_URL",
                    "value": "https://unshelvd.koshkikode.com"
                },
                {
                    "name": "CORS_ALLOWED_ORIGINS",
                    "value": "https://unshelvd.koshkikode.com"
                },
                {
                    "name": "S3_BUCKET_NAME",
                    "value": "unshelvd-uploads"
                },
                {
                    "name": "CDN_BASE_URL",
                    "value": "https://cdn.koshkikode.com"
                },
                {
                    "name": "AWS_REGION",
                    "value": "us-east-1"
                },
                {
                    "name": "SMTP_HOST",
                    "value": "email-smtp.us-east-1.amazonaws.com"
                },
                {
                    "name": "SMTP_PORT",
                    "value": "587"
                },
                {
                    "name": "SMTP_USER",
                    "value": "AKIATZTKKCRD2K4XAT5N"
                },
                {
                    "name": "PAYPAL_CLIENT_ID",
                    "value": "BAApG_OHhkmqjCRm2UZ9UWT_MiF0qlWz6ocdVJgvkq20gX9PXcZ3Rh3Nd0fIltoWbRB4x8u5o51gH4OSvI"
                },
                {
                    "name": "EMAIL_FROM",
                    "value": "Unshelv'd <noreply@koshkikode.com>"
                },
                {
                    "name": "ADMIN_USERNAME",
                    "value": "admin"
                },
                {
                    "name": "ADMIN_EMAIL",
                    "value": "mango.jacq@koshkikode.com"
                },
                {
                    "name": "ADMIN_PASSWORD",
                    "value": "8DViDtrAQ18GaUr/8jJIprOj"
                }
            ],
            "secrets": [
                {
                    "name": "DATABASE_URL",
                    "valueFrom": "arn:aws:secretsmanager:us-east-1:261142221895:secret:unshelvd/DATABASE_URL-g6cChR"
                },
                {
                    "name": "SESSION_SECRET",
                    "valueFrom": "arn:aws:secretsmanager:us-east-1:261142221895:secret:unshelvd/SESSION_SECRET-H1PnJa"
                },
                {
                    "name": "PAYPAL_CLIENT_SECRET",
                    "valueFrom": "arn:aws:secretsmanager:us-east-1:261142221895:secret:unshelvd/PAYPAL_CLIENT_SECRET-xIkkXD"
                },
                {
                    "name": "SMTP_PASS",
                    "valueFrom": "arn:aws:secretsmanager:us-east-1:261142221895:secret:unshelvd/SMTP_PASS-hlga97"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/unshelvd",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                }
            },
            "healthCheck": {
                "command": [
                    "CMD-SHELL",
                    "curl -f http://localhost:8080/api/health || exit 1"
                ],
                "interval": 10,
                "timeout": 5,
                "retries": 3,
                "startPeriod": 30
            }
        }
    ]
}
