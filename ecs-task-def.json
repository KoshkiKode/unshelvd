{
  "family": "unshelvd",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/unshelvd-ecs-execution",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/unshelvd-ecs-task",
  "containerDefinitions": [
    {
      "name": "unshelvd",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/unshelvd:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV",            "value": "production" },
        { "name": "PORT",                "value": "8080" },
        { "name": "APP_URL",             "value": "https://unshelvd.koshkikode.com" },
        { "name": "PUBLIC_APP_URL",      "value": "https://unshelvd.koshkikode.com" },
        { "name": "WEB_BASE_URL",        "value": "https://unshelvd.koshkikode.com" },
        { "name": "CORS_ALLOWED_ORIGINS","value": "https://unshelvd.koshkikode.com" },
        { "name": "S3_BUCKET_NAME",      "value": "unshelvd-uploads" },
        { "name": "AWS_REGION",          "value": "us-east-1" }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:unshelvd/DATABASE_URL"
        },
        {
          "name": "SESSION_SECRET",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:unshelvd/SESSION_SECRET"
        },
        {
          "name": "STRIPE_SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:unshelvd/STRIPE_SECRET_KEY"
        },
        {
          "name": "STRIPE_WEBHOOK_SECRET",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:unshelvd/STRIPE_WEBHOOK_SECRET"
        },
        {
          "name": "PAYPAL_CLIENT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:unshelvd/PAYPAL_CLIENT_SECRET"
        },
        {
          "name": "SMTP_PASS",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:unshelvd/SMTP_PASS"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/unshelvd",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:8080/api/health || exit 1"
        ],
        "interval": 10,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ]
}
