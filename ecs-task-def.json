{
  "family": "unshelvd",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::261142221895:role/unshelvd-ecs-execution",
  "taskRoleArn": "arn:aws:iam::261142221895:role/unshelvd-ecs-task",
  "containerDefinitions": [
    {
      "name": "unshelvd",
      "image": "261142221895.dkr.ecr.us-east-1.amazonaws.com/unshelvd:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV",            "value": "production" },
        { "name": "PORT",                "value": "8080" },
        { "name": "APP_URL",             "value": "https://unshelvd.koshkikode.com" },
        { "name": "PUBLIC_APP_URL",      "value": "https://unshelvd.koshkikode.com" },
        { "name": "WEB_BASE_URL",        "value": "https://unshelvd.koshkikode.com" },
        { "name": "CORS_ALLOWED_ORIGINS","value": "https://unshelvd.koshkikode.com" },
        { "name": "S3_BUCKET_NAME",      "value": "unshelvd-uploads" },
        { "name": "CDN_BASE_URL",        "value": "https://cdn.koshkikode.com" },
        { "name": "AWS_REGION",          "value": "us-east-1" },
        { "name": "SMTP_HOST",           "value": "email-smtp.us-east-1.amazonaws.com" },
        { "name": "SMTP_PORT",           "value": "587" },
        { "name": "SMTP_USER",           "value": "AKIATZTKKCRDVDQE53XW" },
        { "name": "EMAIL_FROM",          "value": "Unshelv'd <noreply@koshkikode.com>" }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "unshelvd/DATABASE_URL"
        },
        {
          "name": "SESSION_SECRET",
          "valueFrom": "unshelvd/SESSION_SECRET"
        },
        {
          "name": "STRIPE_SECRET_KEY",
          "valueFrom": "unshelvd/STRIPE_SECRET_KEY"
        },
        {
          "name": "STRIPE_WEBHOOK_SECRET",
          "valueFrom": "unshelvd/STRIPE_WEBHOOK_SECRET"
        },
        {
          "name": "PAYPAL_CLIENT_SECRET",
          "valueFrom": "unshelvd/PAYPAL_CLIENT_SECRET"
        },
        {
          "name": "PAYPAL_WEBHOOK_ID",
          "valueFrom": "unshelvd/PAYPAL_WEBHOOK_ID"
        },
        {
          "name": "SMTP_PASS",
          "valueFrom": "unshelvd/SMTP_PASS"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/unshelvd",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:8080/api/health || exit 1"
        ],
        "interval": 10,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ]
}
