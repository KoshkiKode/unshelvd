# PostgreSQL connection string
# Local dev (with docker-compose):
DATABASE_URL=postgresql://unshelvd:unshelvd_dev@localhost:5432/unshelvd

# Google Cloud SQL (production):
# DATABASE_URL=postgresql://USER:PASSWORD@/unshelvd?host=/cloudsql/PROJECT:REGION:INSTANCE

# Session secret (change in production!)
SESSION_SECRET=change-me-to-a-random-string

# Port (Cloud Run sets this automatically)
PORT=8080
