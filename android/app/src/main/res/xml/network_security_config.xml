<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Android network_security_config.xml does NOT support CIDR notation.
        Each entry below is treated as an exact hostname.

        For physical device testing on Wi-Fi, add your development machine's
        IP address here (e.g. 192.168.1.100). The emulator host is always
        10.0.2.2 — no change needed for emulator-only development.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Android Emulator → host machine -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- iOS Simulator / localhost -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <!--
            Physical device Wi-Fi testing: replace the placeholder below with
            your dev machine's actual LAN IP (run `ipconfig` / `ifconfig`).
            Example: <domain includeSubdomains="false">192.168.1.42</domain>
        -->
    </domain-config>
    <!-- Production: HTTPS only -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
