{
  "name": "unshelvd",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development tsx server/index.ts",
    "build": "tsx scripts/verify-env.ts && tsx script/build.ts",
    "start": "NODE_ENV=production node dist/index.cjs",
    "check": "tsc",
    "verify:env": "tsx scripts/verify-env.ts",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:run": "node script/migrate.js",
    "db:seed": "node script/seed.js",
    "db:bulk-seed": "tsx server/bulk-seed.ts",
    "db:bootstrap": "node script/migrate.js",
    "cap:sync": "npm run verify:env && npm run build && npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "cap:build:android": "VITE_TARGET=android VITE_API_URL=$API_URL npm run build && npx cap sync android",
    "cap:build:ios": "VITE_TARGET=ios VITE_API_URL=$API_URL npm run build && npx cap sync ios",
    "build:apk": "bash scripts/build-android.sh",
    "build:apk:release": "bash scripts/build-android.sh release",
    "build:ios": "bash scripts/build-ios.sh",
    "build:ios:archive": "bash scripts/build-ios.sh archive",
    "catalog:seed": "tsx server/catalog-import.ts --api",
    "catalog:import": "tsx server/catalog-import.ts",
    "catalog:mass-seed": "tsx server/catalog-mass-seed.ts",
    "catalog:mass-seed:py": "python3 scripts/seed-catalog.py",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
